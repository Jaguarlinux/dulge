[[ -n "$LIBMAKEPKG_UTIL_SH" ]] && return
LIBMAKEPKG_UTIL_SH=1

MAKEPKG_LIBRARY=${MAKEPKG_LIBRARY:-'@libdulgebuilddir@'}

for lib in "$MAKEPKG_LIBRARY/util/"*.sh; do
	source "$lib"
done
